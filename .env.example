# CityBus Environment Variables Example
# Duplicate this file as '.env' for local dev, or set the same keys in Vercel → Settings → Environment Variables.

# The URL of your Supabase project (found in Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# The Publishable Anon Key (found in Project Settings > API)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
